# Backend API base URL (Go backend)
NUXT_PUBLIC_API_BASE=http://localhost:8080/api

# ── Nuxt Studio (CMS) ──
# GitHub OAuth app credentials (create at https://github.com/settings/developers)
# Callback URL: https://your-domain.com/_studio/auth/github
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=
# Optional: override repo details (defaults in nuxt.config.ts)
# STUDIO_REPO_OWNER=dedehudianto12
# STUDIO_REPO_NAME=bbs-frontend
# STUDIO_REPO_BRANCH=main

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
